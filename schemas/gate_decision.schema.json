{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "urn:gap:schema:gate-decision:v1.0",
  "title": "GAP Quality Gate Decision Schema",
  "type": "object",
  "required": ["gate_id","decision","artifact_id","timestamp","decided_by"],
  "properties": {
    "gate_id":     { "type": "string", "enum": ["G1","G2","G3","G4","G5"] },
    "decision":    { "type": "string", "enum": ["PASS","FAIL","CONDITIONAL"] },
    "artifact_id": { "type": "string", "description": "UUIDv7 of the artifact being gated" },
    "timestamp":   { "type": "string", "format": "date-time" },
    "decided_by":  { "type": "string", "description": "Human Orchestrator name or agent_id" },
    "criteria_results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["criterion","result"],
        "properties": {
          "criterion": { "type": "string" },
          "result":    { "type": "string", "enum": ["PASS","FAIL","SKIP","N/A"] },
          "notes":     { "type": "string" }
        }
      }
    },
    "remediation_required": { "type": "boolean" },
    "remediation_plan":     { "type": "string" },
    "next_stage":           { "type": "string" }
  }
}
