{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "urn:cscf:schema:uas-header:v1.1",
  "title": "Universal Artifact Signature (UAS) Header v1.1",
  "description": "Mandatory YAML frontmatter for every artifact. Includes authority, responsibilities, and AI assistance fields. Authored by Quang Cuong Huynh. CAP-01: upgraded from v1.0 to enforce authority + responsibilities.",
  "type": "object",
  "required": ["doc_id","version","status","dc","authority"],
  "properties": {
    "artifact_id":  { "type": "string", "description": "UUIDv7 — empty string until registered by sign_artifact.py" },
    "doc_id": {
      "type": "string",
      "pattern": "^[A-Z0-9]+-[A-Z0-9]+-[A-Z0-9]+-[0-9]{8}-[0-9]{2}$",
      "description": "[DOMAIN]-[PROJECT]-[TAG]-[YYYYMMDD]-[SEQ]"
    },
    "version":    { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+(-[a-z]+)?$" },
    "status":     { "type": "string", "enum": ["draft","active","superseded","deprecated","archived"] },
    "author":     { "type": "string", "default": "Quang Cuong Huynh", "description": "Human who created/ratified this artifact" },
    "authority": {
      "type": "string",
      "description": "Registered intellectual authority. Always: 'Registered — Quang Cuong Huynh'",
      "default": "Registered — Quang Cuong Huynh"
    },
    "responsibilities": {
      "type": "object",
      "description": "Who did what — human author + AI assistants used",
      "properties": {
        "author":     { "type": "string", "description": "Primary human author and intellectual authority" },
        "assistants": {
          "type": "array",
          "description": "AI tools used to assist creation. E.g. Claude, GPT-4, Perplexity, Gemini, NotebookLM",
          "items": { "type": "string" }
        },
        "reviewer":   { "type": "string", "description": "Human reviewer / ratifier (often same as author)" },
        "notes":      { "type": "string", "description": "Any additional responsibility notes" }
      }
    },
    "migrated_from": { "type": "string" },
    "migrated_at":   { "type": "string", "format": "date" },
    "superseded_by": { "type": "string" },
    "sha256":   { "type": "string", "description": "SHA-256 of file body (excl. frontmatter). Set by sign_artifact.py" },
    "dc": {
      "type": "object",
      "required": ["title","type","date"],
      "properties": {
        "title":       { "type": "string" },
        "creator":     { "type": "string", "default": "Quang Cuong Huynh" },
        "date":        { "type": "string", "format": "date" },
        "type":        { "type": "string" },
        "subject":     { "type": "array", "items": { "type": "string" } },
        "description": { "type": "string" },
        "language":    { "type": "string", "default": "en" },
        "rights":      { "type": "string" },
        "identifier":  { "type": "string" }
      }
    },
    "changes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["version","date","author","summary","type"],
        "properties": {
          "version": { "type": "string" },
          "date":    { "type": "string", "format": "date" },
          "author":  { "type": "string" },
          "summary": { "type": "string" },
          "type":    { "type": "string", "enum": ["create","amend","migrate","supersede","deprecate","fix"] }
        }
      }
    }
  }
}
